/* Global Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

/* Header Section */
.header {
    background-color: #2874f0;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 25px;
}

.title {
    font-size: 24px;
    font-weight: bold;
}

/* Search Input */
.input-search {
    width: 45%;
    padding: 8px;
    border: none;
    border-radius: 3px;
}

/* Login Button */
.btn {
    background-color: #fff;
    color: #2874f0;
    border: none;
    padding: 8px 16px;
    cursor: pointer;
    font-weight: bold;
    border-radius: 3px;
}

.btn:hover {
    background-color: #eaeaea;
}

/* Banner Section */
.banner-area {
    background: linear-gradient(to right, #ff9f00, #ffd000);
    text-align: center;
    padding: 70px 20px;
    font-size: 34px;
    font-weight: bold;
}

/* Product Grid */
.grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 25px;
    padding: 25px;
}

/* Product Card */
.box {
    width: 190px;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 12px;
    text-align: center;
    background-color: #fff;
    transition: 0.3s;
}

.box img {
    width: 100%;
    height: auto;
}

/* Hover Effect */
.box:hover {
    transform: scale(1.06);
    box-shadow: 0 5px 12px rgba(0,0,0,0.2);
}

/* Product Name */
.box h3 {
    margin: 10px 0;
    font-size: 18px;
}

/* Price Tag */
.cost {
    color: green;
    font-weight: bold;
    font-size: 16px;
}

/* Responsive Design */
@media (max-width: 768px) {
    .input-search {
        width: 60%;
    }

    .grid {
        flex-direction: column;
        align-items: center;
    }
}
